{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5432;Database=overview;Username=overview;Password=change-me"
  },
  "Persistence": {
    "Provider": "PostgreSQL",
    "ConnectionStringName": "DefaultConnection"
  },
  "Authentication": {
    "Issuer": "Overview.Server",
    "Audience": "Overview.Client",
    "RequireConfirmedEmail": true,
    "JwtSigningKey": "change-me-to-a-long-random-secret",
    "AccessTokenLifetimeMinutes": 60,
    "RefreshTokenLifetimeDays": 30,
    "VerificationCodeLifetimeMinutes": 10
  },
  "Email": {
    "Provider": "smtp",
    "FromAddress": "noreply@example.com"
  },
  "Sync": {
    "MaxBatchSize": 200,
    "ConflictPolicy": "LastModifiedWins"
  }
}
