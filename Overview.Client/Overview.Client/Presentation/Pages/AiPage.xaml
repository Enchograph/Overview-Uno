<Page x:Class="Overview.Client.Presentation.Pages.AiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:components="using:Overview.Client.Presentation.Components"
      xmlns:viewModels="using:Overview.Client.Presentation.ViewModels"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <Grid x:Name="LayoutRoot" Padding="24" RowSpacing="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="0" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="0" />
    </Grid.ColumnDefinitions>

    <StackPanel x:Name="SidebarPanel" Grid.Row="0" Grid.Column="0" Spacing="16">
      <StackPanel Spacing="6">
      <TextBlock x:Name="PageTitleTextBlock" FontSize="28" FontWeight="SemiBold" />
      <TextBlock x:Name="PageDescriptionTextBlock"
                 Opacity="0.72"
                 Style="{ThemeResource BodyStrongTextBlockStyle}"
                 TextWrapping="WrapWholeWords" />
      <Button x:Name="CurrentPeriodButton"
              Click="OnCurrentPeriodButtonClick"
              HorizontalAlignment="Left"
              HorizontalContentAlignment="Left">
        <StackPanel Spacing="4">
          <TextBlock x:Name="CurrentPeriodTextBlock"
                     FontSize="16"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="VisibleRangeTextBlock"
                     Opacity="0.72"
                     Style="{ThemeResource CaptionTextBlockStyle}"
                     TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Button>
      </StackPanel>

    <Border
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="14">
      <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
        <ProgressRing x:Name="BusyIndicator" Width="18" Height="18" IsActive="False" />
        <TextBlock x:Name="StatusTextBlock"
                   TextWrapping="WrapWholeWords" />
      </StackPanel>
    </Border>

    <StackPanel Spacing="12">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="DayModeButton"
                Click="OnDayModeButtonClick"
                Content="Day" />
        <Button x:Name="WeekModeButton"
                Click="OnWeekModeButtonClick"
                Content="Week" />
        <Button x:Name="MonthModeButton"
                Click="OnMonthModeButtonClick"
                Content="Month" />
      </StackPanel>

      <Border x:Name="TimePickerHost"
              Padding="0"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="24"
              Visibility="Collapsed">
        <components:TimeSelectionPicker x:Name="TimeSelectionPicker"
                                        SelectionConfirmed="OnTimeSelectionConfirmed" />
      </Border>
    </StackPanel>
    </StackPanel>

    <Grid x:Name="ConversationPanel" Grid.Row="1" Grid.Column="0">
      <ListView x:Name="MessagesListView"
                SelectionMode="None"
                IsItemClickEnabled="False">
        <ListView.ItemTemplate>
          <DataTemplate x:DataType="viewModels:AiChatMessageEntryViewModel">
            <Border Margin="0,0,0,12"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="16">
              <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="{Binding SpeakerLabel}" />
                <TextBlock Text="{Binding Message}" TextWrapping="WrapWholeWords" />
                <TextBlock Opacity="0.68" Text="{Binding TimestampLabel}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <Border x:Name="EmptyStateBorder"
              Padding="20"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              CornerRadius="16"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <StackPanel Spacing="8">
          <TextBlock Text="No messages yet"
                     FontSize="20"
                     FontWeight="SemiBold" />
          <TextBlock Text="The selected day, week, or month thread will appear here after messages are stored in that period."
                     TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid x:Name="ComposerPanel" Grid.Row="2" Grid.Column="0" ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBox x:Name="ComposerTextBox"
               AcceptsReturn="True"
               MinHeight="96"
               PlaceholderText="Ask AI to help with your schedule, tasks, or notes."
               TextChanged="OnComposerTextChanged"
               TextWrapping="Wrap" />

      <Button x:Name="SendButton"
              Grid.Column="1"
              MinWidth="96"
              Click="OnSendButtonClick"
              Content="Send"
              VerticalAlignment="Stretch" />
    </Grid>
  </Grid>
</Page>
