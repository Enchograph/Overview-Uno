<Page x:Class="Overview.Client.Presentation.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <Grid Padding="24">
    <StackPanel Spacing="12" VerticalAlignment="Center">
      <TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding Title}" />
      <TextBlock Opacity="0.72" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{Binding Description}" TextWrapping="WrapWholeWords" />
    </StackPanel>
  </Grid>
</Page>
