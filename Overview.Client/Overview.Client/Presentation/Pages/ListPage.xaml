<Page x:Class="Overview.Client.Presentation.Pages.ListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:viewModels="using:Overview.Client.Presentation.ViewModels"
      mc:Ignorable="d"
      Background="{StaticResource ListPagePageBackgroundBrush}">
  <Page.Resources>
    <SolidColorBrush x:Key="ListPagePageBackgroundBrush" Color="#FFF6F4EF" />
    <SolidColorBrush x:Key="ListPageHeaderBackgroundBrush" Color="#FFFDFBF4" />
    <SolidColorBrush x:Key="ListPageHeaderBorderBrush" Color="#FFD9D2C3" />
    <SolidColorBrush x:Key="ListPageSectionBackgroundBrush" Color="#FFFFFCF5" />
    <SolidColorBrush x:Key="ListPageSectionBorderBrush" Color="#FFD9D2C3" />
    <SolidColorBrush x:Key="ListPageItemBackgroundBrush" Color="#FFF6F0E6" />
    <SolidColorBrush x:Key="ListPageActiveBadgeBrush" Color="#FFD3A15D" />
    <SolidColorBrush x:Key="ListPageCompletedBadgeBrush" Color="#FFE2CFAE" />
    <SolidColorBrush x:Key="ListPageStatusBrush" Color="#FF8A5A2B" />
  </Page.Resources>
  <Grid Padding="24" RowDefinitions="Auto,Auto,*">
    <StackPanel Spacing="6">
      <TextBlock x:Name="PageTitleTextBlock" FontSize="30" FontWeight="SemiBold" Text="List" />
      <TextBlock
        x:Name="PageSubtitleTextBlock"
        Opacity="0.72"
        Style="{ThemeResource BodyStrongTextBlockStyle}"
        TextWrapping="WrapWholeWords" />
    </StackPanel>

    <Border
      x:Name="ToolbarBorder"
      Grid.Row="1"
      Margin="0,20,0,16"
      Padding="20"
      Background="{StaticResource ListPageHeaderBackgroundBrush}"
      BorderBrush="{StaticResource ListPageHeaderBorderBrush}"
      BorderThickness="1"
      CornerRadius="24">
      <StackPanel Spacing="14">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled">
          <ItemsControl x:Name="TabItemsControl">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="10" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="viewModels:ListPageTabEntryViewModel">
                <Button
                  MinWidth="110"
                  Click="OnTabButtonClick"
                  Content="{Binding Label}"
                  Tag="{Binding Key}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="12">
          <TextBlock
            VerticalAlignment="Center"
            Text="Sort by"
            Style="{ThemeResource BodyStrongTextBlockStyle}" />
          <ComboBox
            x:Name="SortByComboBox"
            Grid.Column="1"
            MinWidth="180"
            SelectionChanged="OnSortBySelectionChanged">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="viewModels:ListPageSortOptionViewModel">
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button
            x:Name="ReorderModeButton"
            Grid.Column="2"
            Click="OnReorderModeButtonClick"
            Content="Reorder Tasks" />
          <ComboBox
            x:Name="ThemeComboBox"
            Grid.Column="3"
            MinWidth="150"
            PlaceholderText="Theme"
            SelectionChanged="OnThemeSelectionChanged">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="viewModels:ListPageThemeOptionViewModel">
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button
            x:Name="MoreSettingsButton"
            Grid.Column="4"
            Click="OnMoreSettingsButtonClick"
            Content="More Settings" />
          <TextBlock
            x:Name="ActiveSummaryTextBlock"
            Grid.Column="5"
            Style="{ThemeResource BodyStrongTextBlockStyle}" />
          <TextBlock
            x:Name="CompletedSummaryTextBlock"
            Grid.Column="6"
            Style="{ThemeResource BodyStrongTextBlockStyle}" />
          <ProgressRing
            x:Name="BusyIndicator"
            Grid.Column="7"
            Width="24"
            Height="24"
            IsActive="False"
            VerticalAlignment="Center" />
        </Grid>

        <TextBlock
          x:Name="StatusTextBlock"
          Foreground="{StaticResource ListPageStatusBrush}"
          TextWrapping="WrapWholeWords" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <Grid>
        <StackPanel x:Name="ContentPanel" Spacing="16">
          <Border
            x:Name="ActiveSectionBorder"
            Padding="20"
            Background="{StaticResource ListPageSectionBackgroundBrush}"
            BorderBrush="{StaticResource ListPageSectionBorderBrush}"
            BorderThickness="1"
            CornerRadius="24">
            <StackPanel Spacing="12">
              <TextBlock FontSize="22" FontWeight="SemiBold" Text="Active Items" />
              <ListView x:Name="ActiveItemsListView" MinHeight="120" SelectionMode="None">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="viewModels:ListPageItemEntryViewModel">
                    <Border
                      Tag="{Binding ItemId}"
                      Margin="0,0,0,10"
                      Padding="14"
                      Background="{StaticResource ListPageItemBackgroundBrush}"
                      CornerRadius="18"
                      Tapped="OnItemContainerTapped">
                      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="12">
                        <Button
                          Width="36"
                          Height="36"
                          Click="OnCompletionButtonClick"
                          Content="{Binding CompletionGlyph}"
                          Tag="{Binding ItemId}" />

                        <Border
                          Grid.Column="1"
                          Width="36"
                          Height="36"
                          Background="{StaticResource ListPageActiveBadgeBrush}"
                          CornerRadius="18">
                          <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{Binding TypeBadge}" />
                        </Border>

                        <StackPanel Grid.Column="2" Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="WrapWholeWords" />
                          <TextBlock Opacity="0.72" Text="{Binding Subtitle}" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="6" VerticalAlignment="Center">
                          <Button
                            HorizontalAlignment="Right"
                            Click="OnImportanceButtonClick"
                            Content="{Binding ImportanceGlyph}"
                            Tag="{Binding ItemId}" />
                          <TextBlock HorizontalAlignment="Right" Text="{Binding CompletionBadge}" />
                          <TextBlock HorizontalAlignment="Right" Text="{Binding ImportanceBadge}" />
                        </StackPanel>

                        <StackPanel Grid.Column="4" Spacing="6" VerticalAlignment="Center">
                          <Button
                            Width="36"
                            Height="32"
                            Click="OnMoveUpButtonClick"
                            Content="↑"
                            IsEnabled="{Binding CanMoveUp}"
                            Tag="{Binding ItemId}" />
                          <Button
                            Width="36"
                            Height="32"
                            Click="OnMoveDownButtonClick"
                            Content="↓"
                            IsEnabled="{Binding CanMoveDown}"
                            Tag="{Binding ItemId}" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>
          </Border>

          <Border
            x:Name="CompletedSectionBorder"
            Padding="20"
            Background="{StaticResource ListPageSectionBackgroundBrush}"
            BorderBrush="{StaticResource ListPageSectionBorderBrush}"
            BorderThickness="1"
            CornerRadius="24">
            <StackPanel Spacing="12">
              <TextBlock FontSize="22" FontWeight="SemiBold" Text="Completed Items" />
              <ListView x:Name="CompletedItemsListView" MinHeight="120" SelectionMode="None">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="viewModels:ListPageItemEntryViewModel">
                    <Border
                      Tag="{Binding ItemId}"
                      Margin="0,0,0,10"
                      Padding="14"
                      Background="{StaticResource ListPageItemBackgroundBrush}"
                      CornerRadius="18"
                      Opacity="0.72"
                      Tapped="OnItemContainerTapped">
                      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="12">
                        <Button
                          Width="36"
                          Height="36"
                          Click="OnCompletionButtonClick"
                          Content="{Binding CompletionGlyph}"
                          Tag="{Binding ItemId}" />

                        <Border
                          Grid.Column="1"
                          Width="36"
                          Height="36"
                          Background="{StaticResource ListPageCompletedBadgeBrush}"
                          CornerRadius="18">
                          <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{Binding TypeBadge}" />
                        </Border>

                        <StackPanel Grid.Column="2" Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="WrapWholeWords" />
                          <TextBlock Opacity="0.72" Text="{Binding Subtitle}" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="6" VerticalAlignment="Center">
                          <Button
                            HorizontalAlignment="Right"
                            Click="OnImportanceButtonClick"
                            Content="{Binding ImportanceGlyph}"
                            Tag="{Binding ItemId}" />
                          <TextBlock HorizontalAlignment="Right" Text="{Binding CompletionBadge}" />
                          <TextBlock HorizontalAlignment="Right" Text="{Binding ImportanceBadge}" />
                        </StackPanel>

                        <StackPanel Grid.Column="4" Spacing="6" VerticalAlignment="Center">
                          <Button
                            Width="36"
                            Height="32"
                            Click="OnMoveUpButtonClick"
                            Content="↑"
                            IsEnabled="{Binding CanMoveUp}"
                            Tag="{Binding ItemId}" />
                          <Button
                            Width="36"
                            Height="32"
                            Click="OnMoveDownButtonClick"
                            Content="↓"
                            IsEnabled="{Binding CanMoveDown}"
                            Tag="{Binding ItemId}" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>
          </Border>
        </StackPanel>

        <Border
          x:Name="EmptyStateBorder"
          Padding="28"
          Background="{StaticResource ListPageSectionBackgroundBrush}"
          BorderBrush="{StaticResource ListPageSectionBorderBrush}"
          BorderThickness="1"
          CornerRadius="24"
          Visibility="Collapsed">
          <StackPanel Spacing="10">
            <TextBlock x:Name="EmptyStateTitleTextBlock" FontSize="24" FontWeight="SemiBold" />
            <TextBlock
              x:Name="EmptyStateDescriptionTextBlock"
              Opacity="0.72"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              TextWrapping="WrapWholeWords" />
          </StackPanel>
        </Border>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
