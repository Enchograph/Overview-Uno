<Page x:Class="Overview.Client.Presentation.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:components="using:Overview.Client.Presentation.Components"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <Grid Padding="24" RowDefinitions="Auto,Auto,*">
    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
      <Button
        x:Name="PreviousPeriodButton"
        Click="OnPreviousPeriodButtonClick"
        Content="&lt;"
        HorizontalAlignment="Left" />

      <Button
        x:Name="PeriodTitleButton"
        Grid.Column="1"
        Click="OnPeriodTitleButtonClick"
        HorizontalAlignment="Center"
        HorizontalContentAlignment="Center">
        <StackPanel Spacing="4">
          <TextBlock
            x:Name="PeriodTitleTextBlock"
            FontSize="28"
            FontWeight="SemiBold"
            TextAlignment="Center" />
          <TextBlock
            x:Name="VisibleRangeTextBlock"
            Opacity="0.72"
            Style="{ThemeResource BodyTextBlockStyle}"
            TextAlignment="Center"
            TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Button>

      <Button
        x:Name="NextPeriodButton"
        Grid.Column="2"
        Click="OnNextPeriodButtonClick"
        Content="&gt;"
        HorizontalAlignment="Right" />
    </Grid>

    <StackPanel Grid.Row="1" Margin="0,18,0,18" Spacing="16">
      <Border
        Padding="18"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="24">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
            <StackPanel Spacing="4">
              <TextBlock
                x:Name="PageTitleTextBlock"
                FontSize="22"
                FontWeight="SemiBold" />
              <TextBlock
                x:Name="PageDescriptionTextBlock"
                Opacity="0.72"
                Style="{ThemeResource BodyTextBlockStyle}"
                TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Button
              x:Name="WeekViewButton"
              Grid.Column="1"
              Click="OnWeekViewButtonClick"
              Content="Week" />

            <Button
              x:Name="MonthViewButton"
              Grid.Column="2"
              Click="OnMonthViewButtonClick"
              Content="Month" />
          </Grid>

          <TextBlock
            x:Name="ViewModeSummaryTextBlock"
            Opacity="0.82"
            Style="{ThemeResource BodyStrongTextBlockStyle}"
            TextWrapping="WrapWholeWords" />

          <TextBlock
            x:Name="GridSummaryTextBlock"
            Opacity="0.72"
            Style="{ThemeResource CaptionTextBlockStyle}"
            TextWrapping="WrapWholeWords" />

          <TextBlock
            x:Name="StatusTextBlock"
            Foreground="{ThemeResource SystemFillColorCautionBrush}"
            TextWrapping="WrapWholeWords" />

          <ProgressRing
            x:Name="BusyIndicator"
            Height="24"
            HorizontalAlignment="Left"
            IsActive="False"
            Width="24" />
        </StackPanel>
      </Border>

      <Border
        x:Name="TimePickerHost"
        Padding="0"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="24"
        Visibility="Collapsed">
        <components:TimeSelectionPicker
          x:Name="TimeSelectionPicker"
          SelectionConfirmed="OnTimeSelectionConfirmed" />
      </Border>
    </StackPanel>

    <Grid Grid.Row="2">
      <Border
        x:Name="LoggedOutStateBorder"
        Padding="24"
        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="24"
        Visibility="Collapsed">
        <StackPanel Spacing="8">
          <TextBlock FontSize="22" FontWeight="SemiBold" Text="Sign in required" />
          <TextBlock
            Text="The homepage timeline loads after authentication. Finish login on the Login page, then return here."
            TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Border>

      <components:HomeTimelineGrid
        x:Name="TimelineGrid"
        InteractionRequested="OnTimelineGridInteractionRequested"
        SwipeRequested="OnTimelineGridSwipeRequested"
        Visibility="Collapsed" />

      <Border
        x:Name="DetailOverlay"
        Padding="16"
        Background="#66000000"
        CornerRadius="24"
        Visibility="Collapsed">
        <Border
          MaxWidth="520"
          Padding="18"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="24"
          HorizontalAlignment="Center"
          VerticalAlignment="Bottom">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock FontSize="22" FontWeight="SemiBold" Text="Item Detail" />
              <Button
                x:Name="CloseDetailButton"
                Grid.Column="1"
                Click="OnCloseDetailButtonClick"
                Content="Close" />
            </Grid>

            <components:ItemDetailCard
              x:Name="ItemDetailCard"
              EditRequested="OnDetailEditRequested" />
          </StackPanel>
        </Border>
      </Border>
    </Grid>
  </Grid>
</Page>
