<Page x:Class="Overview.Client.Presentation.Pages.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <Grid x:Name="RootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="0" />
    </Grid.ColumnDefinitions>

    <Frame x:Name="ContentFrame" Grid.Row="0" Grid.Column="0" />

    <Border
      x:Name="NavigationBorder"
      Grid.Row="1"
      Grid.Column="0"
      Grid.ColumnSpan="2"
      Padding="12"
      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
      BorderThickness="0,1,0,0">
      <StackPanel x:Name="NavigationPanel" Orientation="Horizontal" Spacing="12">
        <Button x:Name="HomeNavigationButton" Click="OnNavigationButtonClick" Content="Home" Tag="Home" />
        <Button x:Name="ListNavigationButton" Click="OnNavigationButtonClick" Content="List" Tag="List" />
        <Button x:Name="AiNavigationButton" Click="OnNavigationButtonClick" Content="AI" Tag="Ai" />
        <Button x:Name="AddNavigationButton" Click="OnNavigationButtonClick" Content="Add" Tag="Add" />
        <Button x:Name="SettingsNavigationButton" Click="OnNavigationButtonClick" Content="Settings" Tag="Settings" />
      </StackPanel>
    </Border>
  </Grid>
</Page>
