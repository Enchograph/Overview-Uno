<UserControl x:Class="Overview.Client.Presentation.Components.HomeTimelineGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer
    x:Name="RootScrollViewer"
    HorizontalScrollBarVisibility="Auto"
    VerticalScrollBarVisibility="Auto"
    ManipulationCompleted="OnRootManipulationCompleted"
    ManipulationMode="TranslateX,System">
    <StackPanel Spacing="12">
      <Grid x:Name="HeaderGrid" ColumnSpacing="8" />
      <Grid x:Name="BodyHostGrid" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
